{
    "extends": "../../../tsconfig.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "composite": true,
        "incremental": true,
        "tsBuildInfoFile": "../../../.build-info/codemirror-lang.tsbuildinfo",
        "jsx": "react",
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src/**/*"],
    "exclude": ["src/**/*.spec.ts", "test/**/*"]
}
