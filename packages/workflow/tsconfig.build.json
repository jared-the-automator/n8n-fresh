{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "strict": false,
        "skipLibCheck": true,
        "composite": true,
        "incremental": true,
        "tsBuildInfoFile": "../../.build-info/workflow.tsbuildinfo",
        "types": ["node", "jest"],
        "paths": {
            "*": ["./types/*"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["src/**/*.spec.ts", "test/**/*"]
}
